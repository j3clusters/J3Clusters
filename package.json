{
  "name": "j3clusters01",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\" && next dev -p 3003",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "smoke": "node scripts/smoke-check.mjs",
    "postinstall": "prisma generate",
    "deploy": "vercel --prod",
    "db:push": "npx -y dotenv-cli@7.4.2 -e .env -e .env.local -- prisma db push",
    "db:seed": "npx -y dotenv-cli@7.4.2 -e .env -e .env.local -- prisma db seed",
    "db:studio": "npx -y dotenv-cli@7.4.2 -e .env -e .env.local -- prisma studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:info": "npx -y dotenv-cli@7.4.2 -e .env.local -- node scripts/print-db-target.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.10",
    "next": "15.3.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "9.24.0",
    "eslint-config-next": "15.3.6",
    "prisma": "^6.14.0",
    "tsx": "^4.20.3",
    "typescript": "5.8.3"
  }
}
