# Dependencies
/node_modules

# Prisma client (generated locally — engines live here on purpose)
/src/generated/

# Next.js
/.next
/out

# Tool caches
.turbo
.eslintcache
coverage

# Vercel CLI link metadata (machine-local)
.vercel

# Env (never commit secrets)
.env
.env.local
.env.*.local

# Local runtime (recycle bin JSON — not seed data)
/var/listing-recycle-bin.json

# Logs / OS
npm-debug.log*
.DS_Store
tsconfig.tsbuildinfo

# StepsStone import media cache (rebuilt by import:stepsstone)
scripts/.stepsstone-media-cache.json

# Local smoke-test artifacts
scripts/smoke-*-cookie.txt
.curl-login.html

# User-uploaded admin images (kept locally, not in git)
/public/uploads/*
!/public/uploads/.gitkeep
