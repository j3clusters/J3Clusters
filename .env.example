DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/j3clusters?schema=public"

ADMIN_JWT_SECRET="replace-me-with-at-least-32-random-characters"
USER_JWT_SECRET="replace-me-with-at-least-32-random-characters"

ADMIN_EMAIL="you@yourdomain.com"
ADMIN_PASSWORD="change-me-after-setup"

# Public site URL for password recovery links (your production domain, no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-domain.example"

# Optional: Resend (https://resend.com) for password recovery emails. Required for recovery in production.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
