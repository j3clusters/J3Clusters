# Local Docker (see docker-compose.yml in repo root):
# DATABASE_URL="postgresql://j3clusters:j3clusters_dev@localhost:5432/j3clusters?schema=public"
#
# Self-hosted or cloud (Neon, Supabase, RDS, …): use the URL from your provider.
# Never set NODE_ENV in .env — Next.js controls it (development vs production vs build).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/j3clusters?schema=public"

# Optional: speed up local dev when Postgres is off or credentials fail (uses bundled listings).
# LISTINGS_SKIP_DB=1
# LISTINGS_DB_TIMEOUT_MS=2500

ADMIN_JWT_SECRET="replace-me-with-at-least-32-random-characters"
USER_JWT_SECRET="replace-me-with-at-least-32-random-characters"

ADMIN_EMAIL="you@yourdomain.com"
ADMIN_PASSWORD="change-me-after-setup"

# Public origin for links (password reset, etc.). No trailing slash.
# Local dev:
NEXT_PUBLIC_APP_URL="http://localhost:3003"
# Vercel temporary hostname (replace with yours from the Vercel dashboard after first deploy):
# NEXT_PUBLIC_APP_URL="https://your-project-name.vercel.app"
# Later, your own domain:
# NEXT_PUBLIC_APP_URL="https://j3clusters.com"

# Vercel Blob (https://vercel.com/docs/storage/vercel-blob) — paste the read/write token from
# Vercel Dashboard → Storage → Blob. Required for consultant uploads on Vercel; omit locally to use public/uploads/.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# Optional: skip startup env assertions (instrumentation) — not recommended for production.
# SKIP_ENV_VALIDATION=1

# --- Production notes ---
# • After pulling schema changes, apply migrations on your **production** Postgres (never run db:sync --accept-data-loss on prod unless you mean it):
#     Set DATABASE_URL to the production connection string, then: npm run db:migrate:deploy
#   Or run this SQL once in your DB console (Neon / Supabase / RDS):
#     ALTER TABLE "Listing" ADD COLUMN IF NOT EXISTS "ownerPhotoUrl" TEXT NOT NULL DEFAULT '';
#     ALTER TABLE "PropertySubmission" ADD COLUMN IF NOT EXISTS "ownerPhotoUrl" TEXT NOT NULL DEFAULT '';
# • For local drift fixes only: `npm run db:sync` (uses prisma db push --accept-data-loss).
# • Serverless hosts (e.g. Vercel): set BLOB_READ_WRITE_TOKEN so listing photos save to Vercel Blob.
#   Without it, uploads fail on Vercel (filesystem is read-only). Local dev can omit the token and use public/uploads/.
# • Set NEXT_PUBLIC_APP_URL to your live HTTPS origin for correct metadata and email links (Vercel sets VERCEL_URL as fallback).

# Optional: Resend (https://resend.com) for password recovery emails. Required for recovery in production.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Public contact email (mailto:, header, footer — never put account passwords here).
# NEXT_PUBLIC_CONTACT_EMAIL="your-public-inbox@example.com"
# Social profile URLs (HTTPS). Icons appear in the footer and contact page when set.
# WhatsApp uses the built-in site number (+91-9965051051) — no env var needed.
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL="https://www.instagram.com/j3clusters2026/"
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL="https://www.facebook.com/profile.php?id=100092451301908"
# NEXT_PUBLIC_SOCIAL_TIKTOK_URL="https://www.tiktok.com/@yourhandle"
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL="https://www.youtube.com/channel/UCX3jPFtRTYzb6X8SgsxMWog"
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL="https://www.linkedin.com/company/yourcompany"
NEXT_PUBLIC_SOCIAL_GOOGLE_REVIEWS_URL="https://search.google.com/local/writereview?placeid=ChIJCaHaellfUjoRkAk0YwHEfns"

# --- Auto-post when admin publishes a listing (optional; never commit live secrets) ---
# Zapier/Make/n8n: POST JSON to your URL; use HMAC header to verify origin.
# AUTO_POST_WEBHOOK_URL=""
# AUTO_POST_WEBHOOK_SECRET=""   # optional: X-J3clusters-Signature header sha256=<hmac-hex>
# AUTO_POST_INCLUDE_INTERNAL_METADATA=0   # 1 = include approvedByEmail in JSON (trusted receivers only)

# Channel webhooks / APIs
# AUTO_POST_DISCORD_WEBHOOK_URL=""
# AUTO_POST_SLACK_WEBHOOK_URL=""
# AUTO_POST_TELEGRAM_BOT_TOKEN=""
# AUTO_POST_TELEGRAM_CHAT_ID=""
# META: Page feed publish (needs pages_manage_posts on the Page access token)
# AUTO_POST_FACEBOOK_PAGE_ID=""
# AUTO_POST_FACEBOOK_PAGE_ACCESS_TOKEN=""

# 1 = also fire hooks when restoring a listing from recycle to PUBLISHED (can duplicate announcements)
# AUTO_POST_ON_RESTORE=0